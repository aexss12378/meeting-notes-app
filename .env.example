COMPOSE_PROJECT_NAME=meeting_notes
NEXT_PUBLIC_API_BASE=http://localhost:8000
REDIS_URL=redis://redis:6379/0
API_CORS_ORIGINS=http://localhost:3000
DATA_DIR=/data/meetings
RETENTION_DAYS=30
TRANSCRIBE_LANGUAGE=zh
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=4
OLLAMA_BASE_URL=http://remote-host:11434/api/chat
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT_SECONDS=180
SUMMARY_CHUNK_CHARS=6000

# Remote Ollama-compatible endpoint.
# Supports either a base URL like http://host:11434
# or a full chat endpoint like http://host:11434/api/chat.
